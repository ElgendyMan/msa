# ============================================================================
# Zero-Budget Autonomous Web Pentesting Framework — .env.example
# Copy to .env and fill in your actual API keys.
# ============================================================================

# PRIMARY (at least one of GEMINI or GROQ required)
GEMINI_API_KEYS=AIzaSy...
GROQ_API_KEYS=gsk_...

# FALLBACK PROVIDERS
CEREBRAS_API_KEYS=csk-...
GITHUB_API_KEYS=ghp_...
OPENROUTER_API_KEYS=sk-or-v1-...
MISTRAL_API_KEYS=...
COHERE_API_KEYS=...
CLOUDFLARE_API_KEYS=cfut_...
CLOUDFLARE_ACCOUNT_ID=...

# LOCAL (optional last-resort)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=dolphin-llama3

# MODELS
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# TUNING
EXECUTION_TIMEOUT_SECONDS=30
EXECUTION_MAX_CONCURRENT=5
EXECUTION_RATE_LIMIT_RPS=10
VALIDATION_CONFIDENCE_THRESHOLD=0.6
HYPOTHESIS_CONFIDENCE_THRESHOLD=0.4
LOG_LEVEL=INFO
SESSION_MAX_RETRIES=3
LLM_MAX_RETRIES=1
LLM_REQUEST_TIMEOUT_SECONDS=30
